{
  "title": "F1 Driver Intelligence",
  "uid": "f1di-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Insight Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 7 },
      "targets": [
        {
          "expr": "sum(rate(f1di_insights_total[1m])) by (risk)",
          "legendFormat": "{{risk}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 2,
      "title": "Insight Latency (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 7 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(f1di_insight_latency_ms_bucket[2m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(f1di_insight_latency_ms_bucket[2m]))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "id": 3,
      "title": "Calibrated Confidence",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 7 },
      "targets": [
        {
          "expr": "f1di_last_confidence",
          "legendFormat": "confidence"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.58 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "HTTP Request Rate by Status",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 7, "w": 8, "h": 7 },
      "targets": [
        {
          "expr": "sum(rate(f1di_http_requests_total[1m])) by (status)",
          "legendFormat": "HTTP {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 5,
      "title": "HTTP Latency p95 by Path",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 7, "w": 8, "h": 7 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(f1di_http_request_latency_ms_bucket[2m])) by (le, path))",
          "legendFormat": "{{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "id": 6,
      "title": "RAG Evidence Count Distribution",
      "type": "histogram",
      "gridPos": { "x": 16, "y": 7, "w": 8, "h": 7 },
      "targets": [
        {
          "expr": "sum(rate(f1di_rag_results_bucket[5m])) by (le)",
          "legendFormat": "{{le}} items"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 7,
      "title": "Insights by Risk Level",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 14, "w": 8, "h": 7 },
      "targets": [
        {
          "expr": "sum(increase(f1di_insights_total[1h])) by (risk)",
          "legendFormat": "{{risk}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Insights by Policy",
      "type": "piechart",
      "gridPos": { "x": 8, "y": 14, "w": 8, "h": 7 },
      "targets": [
        {
          "expr": "sum(increase(f1di_insights_total[1h])) by (policy)",
          "legendFormat": "{{policy}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Readiness Check Results",
      "type": "stat",
      "gridPos": { "x": 16, "y": 14, "w": 8, "h": 7 },
      "targets": [
        {
          "expr": "sum(increase(f1di_ready_check_total{status='ready'}[5m]))",
          "legendFormat": "ready"
        },
        {
          "expr": "sum(increase(f1di_ready_check_total{status='not_ready'}[5m]))",
          "legendFormat": "not_ready"
        }
      ]
    }
  ]
}
