# F1 Driver Intelligence — environment configuration
# Copy this file to .env and fill in your values.
# docker compose uses this file directly via env_file.

# ── LLM backend ───────────────────────────────────────────────────────────────
# rules           : deterministic rules only, no external LLM (default, works offline)
# openai_compatible: local Ollama or any OpenAI-compatible endpoint
# anthropic       : Anthropic Claude API
F1DI_LLM_BACKEND=rules

# Ollama (used when LLM_BACKEND=openai_compatible)
# F1DI_LLM_BACKEND=openai_compatible
# F1DI_LLM_OPEN_SOURCE_MODEL=llama3.1
# F1DI_LLM_BASE_URL=http://ollama:11434/v1
# F1DI_LLM_TIMEOUT_MS=30000

# Anthropic Claude (used when LLM_BACKEND=anthropic)
# F1DI_LLM_BACKEND=anthropic
# F1DI_LLM_ADVICE_MODEL=claude-sonnet-4-6
# F1DI_ANTHROPIC_API_KEY=sk-ant-...

# ── Vector backend ────────────────────────────────────────────────────────────
# memory : in-process BM25 + dense retrieval, no external service required
# qdrant : production-grade hybrid retrieval (default when docker compose is used)
F1DI_VECTOR_BACKEND=qdrant
F1DI_QDRANT_URL=http://qdrant:6333
F1DI_QDRANT_COLLECTION=f1_knowledge
# F1DI_EMBEDDING_OFFLINE=true  # set after first run to skip HuggingFace network checks on cold start

# ── General ───────────────────────────────────────────────────────────────────
F1DI_ENV=local
# F1DI_DETERMINISTIC=true  # bypass LLM, use rules-only output — for CI and regression gates
F1DI_LOG_LEVEL=INFO
F1DI_KNOWLEDGE_PATH=data/knowledge

# ── FastF1 cache ──────────────────────────────────────────────────────────────
# F1DI_FASTF1_CACHE=data/fastf1_cache

# ── Persistence (SQLAlchemy) ──────────────────────────────────────────────────
# SQLite (dev/test, zero config):
F1DI_STORAGE_URL=sqlite:///./f1di.db
# PostgreSQL (production):
# F1DI_STORAGE_URL=postgresql://user:pass@localhost:5432/f1di

# ── Analytics (Text-to-SQL via DuckDB + Ollama) ───────────────────────────────
# Install: pip install 'f1-driver-intelligence[analytics]'
# Then hit POST /v1/analytics/query with {"question": "..."}
# Requires F1DI_LLM_BACKEND=openai_compatible and Ollama running.
# Recommended model: ollama pull qwen2.5-coder:7b

# ── Document ingestion (PDF + OCR) ────────────────────────────────────────────
# Install: pip install 'f1-driver-intelligence[ocr]'
# Also: sudo apt install tesseract-ocr
# Then upload via POST /v1/documents/ingest (multipart form)

# ── Push delivery (Telegram + Slack) ─────────────────────────────────────────
# Telegram: create a bot via @BotFather, get the chat_id via @userinfobot
# F1DI_TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# F1DI_TELEGRAM_CHAT_ID=-1001234567890
# Slack: create an incoming webhook at api.slack.com/messaging/webhooks
# F1DI_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
# F1DI_NOTIFY_MIN_RISK=WARNING

# ── Background ingestion scheduler ───────────────────────────────────────────
# F1DI_INGESTION_AUTO_ENABLED=true
# F1DI_INGESTION_INTERVAL_HOURS=6
# F1DI_INGESTION_YEARS=2023,2024

# ── Tiered knowledge base (hot/cold) ─────────────────────────────────────────
# F1DI_VECTOR_BACKEND=tiered
# F1DI_TIERED_HOT_SEASONS=2
# F1DI_TIERED_MIN_HOT_RESULTS=2
