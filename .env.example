# F1 Driver Intelligence — environment configuration
# Copy this file to .env and fill in your values.
# docker compose uses this file directly via env_file.

# ── LLM backend ───────────────────────────────────────────────────────────────
# rules           : deterministic rules only, no external LLM (default, works offline)
# openai_compatible: local Ollama or any OpenAI-compatible endpoint
# anthropic       : Anthropic Claude API
F1DI_LLM_BACKEND=rules

# Ollama (used when LLM_BACKEND=openai_compatible)
# F1DI_LLM_BACKEND=openai_compatible
# F1DI_LLM_OPEN_SOURCE_MODEL=llama3.1
# F1DI_LLM_BASE_URL=http://ollama:11434/v1
# F1DI_LLM_TIMEOUT_MS=30000

# Anthropic Claude (used when LLM_BACKEND=anthropic)
# F1DI_LLM_BACKEND=anthropic
# F1DI_LLM_ADVICE_MODEL=claude-sonnet-4-6
# F1DI_ANTHROPIC_API_KEY=sk-ant-...

# ── Vector backend ────────────────────────────────────────────────────────────
# memory : in-process BM25 + dense retrieval, no external service required
# qdrant : production-grade hybrid retrieval (default when docker compose is used)
F1DI_VECTOR_BACKEND=qdrant
F1DI_QDRANT_URL=http://qdrant:6333
F1DI_QDRANT_COLLECTION=f1_knowledge

# ── General ───────────────────────────────────────────────────────────────────
F1DI_ENV=local
F1DI_LOG_LEVEL=INFO
F1DI_KNOWLEDGE_PATH=data/knowledge

# ── FastF1 cache ──────────────────────────────────────────────────────────────
# Session telemetry is cached here after first download (~50 MB per session).
# Defaults to data/fastf1_cache/ inside the project root.
# F1DI_FASTF1_CACHE=data/fastf1_cache
